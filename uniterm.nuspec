<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>uniTerm</id>
    <version>1.4.1</version>
    <title>uniTerm</title>
    <authors>ys-ll</authors>
    <projectUrl>https://uniterm.net</projectUrl>
    <projectSourceUrl>https://github.com/ys-ll/uniterm</projectSourceUrl>
    <iconUrl>https://github.com/ys-ll/uniterm/raw/main/build/appicon.png</iconUrl>
    <copyright>ys-ll</copyright>
    <licenseUrl>https://uniterm.net/license</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>uniTerm is a lightweight, cross-platform terminal emulator with built-in AI Agent. It supports multiple connection protocols including SSH, RDP, SFTP, serial connections, and integrates a local AI Agent for intelligent command assistance. All-in-one solution for developers and system administrators.</description>
    <tags>terminal ssh rdp sftp serial emulator cross-platform</tags>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
  </files>
</package>
